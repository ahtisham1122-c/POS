# ─── NOON DAIRY BACKEND — PRODUCTION ENVIRONMENT ───────────────────────────
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the real .env file to git.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase: Dashboard > Project Settings > Database > Connection string (URI)
# OR any PostgreSQL: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:STRONG_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_REFRESH_TTL_DAYS=30

# ── Sync ─────────────────────────────────────────────────────────────────────
# Must match SYNC_DEVICE_SECRET in the Electron app's .env / settings
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_DEVICE_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Only needed if you build a web dashboard. For Electron-only, leave as is.
CORS_ORIGINS="https://your-dashboard-domain.com"
