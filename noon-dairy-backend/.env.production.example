# ─── NOON DAIRY BACKEND — PRODUCTION ENVIRONMENT (VPS) ─────────────────────
# Copy this file to .env on your VPS and fill in the values.
# The scripts/server-setup.sh script creates the database and user for you.
# NEVER commit the real .env to git.

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Local PostgreSQL on the same VPS — no SSL needed for localhost connections.
# Replace YOUR_DB_PASSWORD with the password you set during server-setup.sh
DATABASE_URL="postgresql://noon_dairy:YOUR_DB_PASSWORD@localhost:5432/noon_dairy_db"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate all 3 secrets — run this command 3 times, use a different value each:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_96_CHAR_RANDOM_HEX"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_96_CHAR_RANDOM_HEX"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_REFRESH_TTL_DAYS=30

# ─── SYNC ─────────────────────────────────────────────────────────────────────
# Must match SYNC_DEVICE_SECRET in the Electron app Settings > Sync
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_DEVICE_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Electron desktop app does not need CORS.
# Only add your domain here if you build a web dashboard.
CORS_ORIGINS="https://your-dashboard-domain.com"
