generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  username     String        @unique
  passwordHash String
  role         Role          @default(CASHIER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
  sales        Sale[]
  refreshTokens RefreshToken[]

  @@index([username])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Product {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  category          ProductCategory
  unit              String
  sellingPrice      Decimal         @db.Decimal(10, 2)
  costPrice         Decimal         @db.Decimal(10, 2)
  stock             Decimal         @db.Decimal(10, 3)
  lowStockThreshold Decimal         @default(5) @db.Decimal(10, 3)
  taxExempt         Boolean         @default(false)
  emoji             String          @default("📦")
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  saleItems         SaleItem[]
  stockMovements    StockMovement[]

  @@index([category])
  @@index([code])
}

model DailyRate {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  milkRate    Decimal  @db.Decimal(10, 2)
  yogurtRate  Decimal  @db.Decimal(10, 2)
  updatedById String
  createdAt   DateTime @default(now())

  @@index([date])
}

model Customer {
  id             String        @id @default(cuid())
  code           String        @unique
  cardNumber     String?       @unique
  name           String
  phone          String?
  address        String?
  creditLimit    Decimal       @default(0) @db.Decimal(10, 2)
  currentBalance Decimal       @default(0) @db.Decimal(10, 2)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ledgerEntries  LedgerEntry[]
  payments       Payment[]
  sales          Sale[]

  @@index([phone])
  @@index([name])
  @@index([cardNumber])
}

model Sale {
  id             String        @id @default(cuid())
  transactionId  String?       @unique
  shiftId        String?
  billNumber     String        @unique
  saleDate       DateTime      @default(now())
  customerId     String?
  cashierId      String
  paymentType    PaymentType
  subtotal       Decimal       @db.Decimal(10, 2)
  discountType   DiscountType  @default(NONE)
  discountValue  Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  taxEnabled     Boolean       @default(false)
  taxLabel       String        @default("Tax")
  taxRate        Decimal       @default(0) @db.Decimal(10, 2)
  taxableAmount  Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  grandTotal     Decimal       @db.Decimal(10, 2)
  amountPaid     Decimal       @db.Decimal(10, 2)
  cashTendered   Decimal       @default(0) @db.Decimal(10, 2)
  changeReturned Decimal       @default(0) @db.Decimal(10, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(10, 2)
  status         SaleStatus    @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ledgerEntries  LedgerEntry[]
  payments       Payment[]
  splitPayments  SplitPayment[]
  cashier        User          @relation(fields: [cashierId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  shift          Shift?        @relation(fields: [shiftId], references: [id])
  items          SaleItem[]

  @@index([saleDate])
  @@index([shiftId])
  @@index([customerId])
  @@index([billNumber])
  @@index([paymentType])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  productName String
  unit        String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  costPrice   Decimal @db.Decimal(10, 2)
  discountType   DiscountType @default(NONE)
  discountValue  Decimal      @default(0) @db.Decimal(10, 2)
  discountAmount Decimal      @default(0) @db.Decimal(10, 2)
  lineTotal   Decimal @db.Decimal(10, 2)
  product     Product @relation(fields: [productId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model LedgerEntry {
  id           String          @id @default(cuid())
  customerId   String
  saleId       String?
  paymentId    String?
  entryType    LedgerEntryType
  amount       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @db.Decimal(10, 2)
  description  String
  entryDate    DateTime        @default(now())
  createdAt    DateTime        @default(now())
  customer     Customer        @relation(fields: [customerId], references: [id])
  payment      Payment?        @relation(fields: [paymentId], references: [id])
  sale         Sale?           @relation(fields: [saleId], references: [id])

  @@index([customerId])
  @@index([entryDate])
}

model Payment {
  id            String        @id @default(cuid())
  customerId    String
  saleId        String?
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  collectedById String
  notes         String?
  createdAt     DateTime      @default(now())
  ledgerEntries LedgerEntry[]
  customer      Customer      @relation(fields: [customerId], references: [id])
  sale          Sale?         @relation(fields: [saleId], references: [id])

  @@index([customerId])
  @@index([paymentDate])
}

model SplitPayment {
  id           String   @id
  saleId       String
  method       String
  amount       Decimal  @db.Decimal(10, 2)
  customerId   String?
  receivedById String
  createdAt    DateTime @default(now())
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
  @@index([createdAt])
}

model StockMovement {
  id           String            @id @default(cuid())
  productId    String
  movementType StockMovementType
  quantity     Decimal           @db.Decimal(10, 3)
  stockBefore  Decimal           @db.Decimal(10, 3)
  stockAfter   Decimal           @db.Decimal(10, 3)
  referenceId  String?
  supplier     String?
  notes        String?
  createdById  String
  createdAt    DateTime          @default(now())
  product      Product           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@index([movementType])
}

model Expense {
  id          String          @id @default(cuid())
  code        String          @unique
  shiftId     String?
  expenseDate DateTime        @db.Date
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  shift       Shift?          @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@index([expenseDate])
  @@index([category])
}

model CashRegister {
  id             String    @id @default(cuid())
  shiftId        String?   @unique
  date           DateTime  @db.Date
  openingBalance Decimal   @default(0) @db.Decimal(10, 2)
  cashIn         Decimal   @default(0) @db.Decimal(10, 2)
  cashOut        Decimal   @default(0) @db.Decimal(10, 2)
  closingBalance Decimal   @default(0) @db.Decimal(10, 2)
  isClosedForDay Boolean   @default(false)
  closedById     String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  shift          Shift?    @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@index([date])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Device {
  id             String    @id @default(cuid())
  deviceId       String    @unique
  deviceName     String
  terminalNumber Int
  syncTokenHash  String?
  tokenIssuedAt  DateTime?
  revokedAt      DateTime?
  lastSeenAt     DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
}

model Return {
  id           String   @id
  returnNumber String   @unique
  saleId       String
  shiftId      String?
  billNumber   String
  customerId   String?
  cashierId    String
  returnDate   DateTime
  refundMethod String
  refundAmount Decimal  @db.Decimal(10, 2)
  reason       String
  restockItems Boolean  @default(true)
  status       String   @default("COMPLETED")
  createdAt    DateTime @default(now())
  shift        Shift?   @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@index([saleId])
  @@index([returnDate])
  @@index([returnNumber])
}

model SaleVoid {
  id             String   @id
  saleId         String   @unique
  shiftId        String?
  billNumber     String
  voidedById     String
  voidedAt       DateTime
  reason         String
  cashReversed   Decimal  @default(0) @db.Decimal(10, 2)
  creditReversed Decimal  @default(0) @db.Decimal(10, 2)
  restockedItems Boolean  @default(true)
  createdAt      DateTime @default(now())
  shift          Shift?   @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@index([saleId])
  @@index([voidedAt])
  @@index([billNumber])
}

model ReturnItem {
  id          String   @id
  returnId    String
  saleItemId  String
  productId   String
  productName String
  unit        String
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
}

model Supplier {
  id             String   @id
  code           String   @unique
  name           String
  phone          String?
  address        String?
  allowedShifts  String   @default("BOTH")
  defaultRate    Decimal  @default(0) @db.Decimal(10, 2)
  cowRate        Decimal  @default(0) @db.Decimal(10, 2)
  buffaloRate    Decimal  @default(0) @db.Decimal(10, 2)
  currentBalance Decimal  @default(0) @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

model MilkCollection {
  id             String   @id
  supplierId     String
  collectionDate DateTime @db.Date
  shift          String
  milkType       String   @default("MIXED")
  quantity       Decimal  @db.Decimal(10, 3)
  rate           Decimal  @db.Decimal(10, 2)
  totalAmount    Decimal  @db.Decimal(10, 2)
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())

  @@index([supplierId])
  @@index([collectionDate])
}

model SupplierPayment {
  id          String   @id
  supplierId  String
  amount      Decimal  @db.Decimal(10, 2)
  paymentDate DateTime
  paidById    String
  notes       String?
  createdAt   DateTime @default(now())

  @@index([supplierId])
  @@index([paymentDate])
}

model SupplierLedgerEntry {
  id           String   @id
  supplierId   String
  collectionId String?
  paymentId    String?
  entryType    String
  amount       Decimal  @db.Decimal(10, 2)
  balanceAfter Decimal  @db.Decimal(10, 2)
  description  String
  entryDate    DateTime
  createdAt    DateTime @default(now())

  @@index([supplierId])
  @@index([entryDate])
}

model ReceiptAuditSession {
  id            String   @id
  auditDate     DateTime @db.Date
  countedById   String
  expectedCount Int
  expectedAmount Decimal @db.Decimal(10, 2)
  countedCount  Int
  countedAmount Decimal @db.Decimal(10, 2)
  missingCount  Int
  missingAmount Decimal @db.Decimal(10, 2)
  extraCount    Int
  duplicateCount Int
  notes         String?
  createdAt     DateTime @default(now())

  @@index([auditDate])
}

model ReceiptAuditEntry {
  id        String   @id
  sessionId String
  billNumber String
  saleId    String?
  amount    Decimal  @default(0) @db.Decimal(10, 2)
  status    String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([billNumber])
}

model Shift {
  id                    String   @id
  shiftDate             DateTime @db.Date
  openedById            String
  closedById            String?
  openedAt              DateTime
  closedAt              DateTime?
  openingCash           Decimal  @default(0) @db.Decimal(10, 2)
  expectedCash          Decimal  @default(0) @db.Decimal(10, 2)
  closingCash           Decimal  @default(0) @db.Decimal(10, 2)
  cashVariance          Decimal  @default(0) @db.Decimal(10, 2)
  receiptAuditSessionId String?
  status                String   @default("OPEN")
  notes                 String?
  sales                 Sale[]
  returns               Return[]
  saleVoids             SaleVoid[]
  expenses              Expense[]
  cashRegisters         CashRegister[]

  @@index([shiftDate])
  @@index([status])
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  STAFF
}

enum ProductCategory {
  MILK
  YOGURT
  BUTTER_CREAM
  DRINKS
  CHEESE
  SWEETS
  OTHER
}

enum PaymentType {
  CASH
  ONLINE
  CREDIT
  SPLIT
  PARTIAL
}

enum SaleStatus {
  COMPLETED
  HELD
  RETURNED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum DiscountType {
  NONE
  FLAT
  PERCENTAGE
}

enum LedgerEntryType {
  SALE_CREDIT
  PAYMENT_RECEIVED
  ADVANCE_PAYMENT
  ADJUSTMENT
  RETURN_CREDIT_ADJUSTMENT
  VOID_CREDIT_ADJUSTMENT
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  RETURN_IN
  VOID_RESTOCK
  MILK_COLLECTION
  WASTAGE
  ADJUSTMENT
  OPENING
  DELIVERY_OUT
  DELIVERY_RETURN
}

enum ExpenseCategory {
  MILK_PURCHASE
  SALARY
  ELECTRICITY
  FUEL
  PACKAGING
  RENT
  MAINTENANCE
  CLEANING
  MISCELLANEOUS
}
