{
  "name": "noon-dairy-pos-electron",
  "version": "1.0.0",
  "description": "Offline-first POS system for Gujjar Milk Shop",
  "author": "Gujjar Milk Shop",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "rebuild:native": "electron-builder install-app-deps",
    "dev:electron": "npm run rebuild:native && npm run build:renderer && npm run build:electron && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run rebuild:native && npm run build:renderer && npm run build:electron && electron-builder",
    "build:win": "npm run rebuild:native && npm run build:renderer && npm run build:electron && electron-builder --win",
    "test:sales-math": "npm run build:electron && node scripts/sales-math-smoke.cjs",
    "test:sync-security": "npm run build:electron && node scripts/sync-security-smoke.cjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.3.4",
    "lucide-react": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.31",
    "tailwindcss": "3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.noondairy.pos",
    "productName": "Noon Dairy POS",
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
